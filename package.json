{
  "name": "headai-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Headai Core Engine — knowledge graphs, recommendations, scorecards, and signals",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "headai-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx watch src/index.ts",
    "build": "npx tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.21.0",
    "typescript": "^5.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2"
  }
}
