{
  "name": "@headai/mcp-server",
  "version": "1.3.2",
  "description": "MCP server for Headai Core Engine — knowledge graphs, skill analytics, recommendations, scorecards, and signals. Connect Claude, ChatGPT, or any MCP client to Headai's AI workforce intelligence APIs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "headai-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx watch src/index.ts",
    "build": "npx tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "headai",
    "knowledge-graph",
    "skills",
    "workforce-intelligence",
    "ai",
    "claude",
    "chatgpt",
    "anthropic",
    "openai"
  ],
  "author": "Headai Oy <info@headai.com> (https://headai.com)",
  "license": "MIT",
  "homepage": "https://headai.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Headai/headai-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/Headai/headai-mcp-server/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
